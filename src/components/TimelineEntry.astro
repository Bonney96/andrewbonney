---
import type { TimelineEntry } from '../data/timeline';

interface Props {
  entry: TimelineEntry;
}

const { entry } = Astro.props;

const typeColors = {
  education: 'border-indigo bg-indigo',
  work: 'border-moss bg-moss',
} as const;
---

<div class="relative pl-8 pb-16 last:pb-0 group animate-on-scroll">
  <!-- Timeline line -->
  <div class="absolute left-[7px] top-3 bottom-0 w-px bg-hairline group-last:hidden"></div>

  <!-- Timeline dot -->
  <div class={`absolute left-0 top-2 w-5 h-5 rounded-full border-2 ${typeColors[entry.type]}/40`}>
    <div class={`absolute inset-[3px] rounded-full ${typeColors[entry.type]}`}></div>
  </div>

  <!-- Content -->
  <div class="relative">
    <!-- Organization — visual star -->
    <h3 class="font-serif text-xl font-bold text-text mb-0.5">{entry.organization}</h3>

    <!-- Role title + date row -->
    <div class="flex flex-wrap items-center justify-between gap-x-4 gap-y-0.5 mb-3">
      <p class="font-mono text-sm text-text-muted">{entry.title}</p>
      <span class="font-mono text-xs text-text-faint sm:absolute sm:right-0 sm:top-0">{entry.date}</span>
    </div>

    <!-- Description -->
    <p class="text-text-muted text-base leading-relaxed max-w-xl">{entry.description}</p>

    <!-- Tags -->
    {entry.tags && (
      <div class="flex flex-wrap gap-2 mt-3">
        {entry.tags.map((tag) => (
          <span class="font-mono text-[10px] text-text-faint px-1.5 py-0.5 border border-hairline rounded-sm">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</div>
