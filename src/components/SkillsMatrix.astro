---
import { skillCategories } from '../data/skills';

const accentMap: Record<string, string> = {
  moss: 'text-moss',
  indigo: 'text-indigo',
  terracotta: 'text-terracotta',
  amber: 'text-amber',
  'text-muted': 'text-text-muted',
};

const chipBorderMap: Record<string, string> = {
  moss: 'border-moss/30 bg-moss/10 text-moss',
  indigo: 'border-indigo/30 bg-indigo/10 text-indigo',
  terracotta: 'border-terracotta/30 bg-terracotta/10 text-terracotta',
  amber: 'border-amber/30 bg-amber/10 text-amber',
  'text-muted': 'border-hairline-strong bg-surface text-text-muted',
};

const levelOpacity: Record<string, string> = {
  advanced: 'opacity-100',
  proficient: 'opacity-60',
  familiar: 'opacity-40',
};
---

<section id="skills" class="py-20 sm:py-28 bg-surface/30">
  <div class="mx-auto max-w-5xl px-6">
    <!-- Section header -->
    <div class="mb-12 flex items-end justify-between section-divider pb-4">
      <div>
        <span class="font-mono text-xs text-text-faint uppercase tracking-wider block mb-2">02</span>
        <h2 class="font-serif text-3xl sm:text-4xl font-semibold">Technical Skills</h2>
      </div>
      <span class="font-mono text-xs text-text-faint">
        {skillCategories.reduce((sum, cat) => sum + cat.skills.length, 0)} capabilities
      </span>
    </div>

    <!-- Proficiency legend -->
    <div class="flex items-center gap-5 font-mono text-[10px] text-text-faint mb-8">
      <span class="uppercase tracking-wider mr-1">Proficiency:</span>
      <span class="opacity-100">&#9632; Advanced</span>
      <span class="opacity-60">&#9632; Proficient</span>
      <span class="opacity-40">&#9632; Familiar</span>
    </div>

    <!-- Spec sheet rows -->
    <div class="divide-y divide-hairline">
      {skillCategories.map((category) => (
        <div class="flex flex-col sm:flex-row gap-3 sm:gap-6 py-5 animate-on-scroll">
          <!-- Category label — 25% width on sm+ -->
          <div class="sm:w-1/4 shrink-0">
            <span class={`font-serif text-xl font-semibold ${accentMap[category.accent]}`}>
              {category.label}
            </span>
          </div>

          <!-- Skill chips — 75% width -->
          <div class="flex-1 flex flex-wrap gap-2">
            {category.skills.map((skill) => (
              <span class={`inline-flex items-center font-mono text-[11px] px-2 py-1 border rounded-sm ${chipBorderMap[category.accent]} ${skill.level ? levelOpacity[skill.level] : 'opacity-100'}`}>
                {skill.name}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
